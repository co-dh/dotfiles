set-face global ts_namespace "%opt{scale_orange_6}"
set-face global ts_operator "%opt{scale_blue_8}"
set-face global ts_punctuation "%opt{fg_default}"
set-face global ts_punctuation_bracket "%opt{fg_default}"
set-face global ts_punctuation_delimiter "%opt{fg_default}"
set-face global ts_punctuation_special "%opt{fg_default}"
set-face global ts_special "%opt{scale_blue_8}"
set-face global ts_string "%opt{scale_blue_8}"

set-face global ts_keyword_storage_type "%opt{scale_red_5}"
set-face global ts_label "%opt{scale_red_5}"
set-face global ts_markup_bold "+b"
set-face global ts_markup_heading "%opt{scale_blue_6}"
set-face global ts_markup_heading_1 "%opt{scale_blue_6}"
set-face global ts_markup_heading_2 "%opt{scale_blue_6}"

set-face global ts_markup_italic "+i"
set-face global ts_markup_link_text "%opt{blue_warmer}+u"
set-face global ts_markup_link_url "%opt{cyan}"
set-face global ts_markup_list_checked "%opt{yellow_warmer}"
set-face global ts_markup_list_numbered "%opt{fg_dim}"
set-face global ts_markup_list_unchecked "%opt{yellow_warmer}"
set-face global ts_markup_list_unnumbered "%opt{fg_dim}"
set-face global ts_markup_raw "%opt{green_cooler}"
set-face global ts_markup_raw_block "%opt{green_cooler}"
set-face global ts_markup_raw_inline "%opt{green_cooler}"
set-face global ts_markup_strikethrough "+s"

set-face global ts_constant_numeric "%opt{blue_cooler}"
set-face global ts_constant_numeric_float "%opt{blue_cooler}"
set-face global ts_constant_numeric_integer "%opt{blue_cooler}"
set-face global ts_constructor "%opt{cyan_cooler}"
set-face global ts_diff_delta "%opt{fg_changed},%opt{bg_changed}"
set-face global ts_diff_delta_gutter "%opt{yellow_intense}"
set-face global ts_diff_delta_moved "%opt{fg_changed},%opt{bg_changed}"
set-face global ts_diff_minus "%opt{fg_removed},%opt{bg_removed}"

declare-option str fg_removed "rgb:553d00"
declare-option str bg_paren_match "rgb:5fcfff"
declare-option str border_mode_line_active "rgb:4f4f74"

set-face global Default "%opt{fg_main},%opt{bg_main}"

set-face global ts_attribute "%opt{cyan_cooler}"
set-face global ts_comment "%opt{yellow_cooler}"
set-face global ts_comment_block "%opt{yellow_cooler}"
set-face global ts_comment_line "%opt{yellow_cooler}"
set-face global ts_constant "%opt{blue_cooler}"
set-face global ts_constant_builtin_boolean "%opt{blue_cooler}"
set-face global ts_constant_character "%opt{blue_cooler}"
set-face global ts_constant_character_escape "%opt{magenta}"

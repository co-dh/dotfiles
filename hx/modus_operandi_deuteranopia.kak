declare-option str bg_hl_line "rgb:dae5ec"
declare-option str bg_mode_line_active "rgb:d0d6ff"
declare-option str fg_mode_line_active "rgb:0f0f0f"
declare-option str bg_mode_line_inactive "rgb:e6e6e6"

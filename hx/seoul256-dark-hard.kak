set-face global ts_markup_heading_1 "%opt{salmon2}+b"
set-face global ts_markup_heading_2 "%opt{salmon2}+b"
set-face global ts_markup_heading_3 "%opt{salmon2}+b"
set-face global ts_markup_heading_4 "%opt{salmon2}+b"
set-face global ts_markup_heading_5 "%opt{salmon2}+b"
set-face global ts_markup_heading_6 "%opt{salmon2}+b"
set-face global ts_markup_heading_marker "%opt{salmon2}+b"
set-face global ts_markup_italic "%opt{magenta1}+i"
set-face global ts_markup_link_text "%opt{salmon2}"
set-face global ts_markup_link_url "%opt{cyan}+u"
set-face global ts_markup_list_checked "%opt{salmon}"
set-face global ts_markup_list_numbered "%opt{salmon}"
set-face global ts_markup_list_unchecked "%opt{salmon}"
set-face global ts_markup_list_unnumbered "%opt{salmon}"
set-face global ts_markup_quote "%opt{yellow}"
set-face global ts_markup_raw "%opt{green}"
set-face global ts_markup_raw_block "%opt{green}"
set-face global ts_markup_raw_inline "%opt{green}"
set-face global ts_markup_strikethrough "+s"
set-face global ts_namespace "%opt{cyan}"
set-face global ts_operator "%opt{yellow3}"
set-face global ts_punctuation "%opt{brown}"
set-face global ts_punctuation_bracket "%opt{brown}"
set-face global ts_punctuation_delimiter "%opt{brown}"
set-face global ts_punctuation_special "%opt{brown}"
set-face global ts_special "%opt{yellow2}"
set-face global ts_string "%opt{blue}"
set-face global ts_string_regex "%opt{blue}"
set-face global ts_string_regexp "%opt{blue}"
set-face global ts_string_special "%opt{blue}"
set-face global ts_string_special_path "%opt{blue}"
set-face global ts_string_special_symbol "%opt{blue}"
set-face global ts_string_symbol "%opt{blue}"
set-face global ts_type "%opt{yellow}"
set-face global ts_type_builtin "%opt{salmon}"

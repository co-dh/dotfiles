set-face global ts_keyword_control_repeat "%opt{mauve}"
set-face global ts_keyword_control_return "%opt{mauve}"
set-face global ts_keyword_directive "%opt{mauve}"
set-face global ts_keyword_function "%opt{mauve}"
set-face global ts_keyword_operator "%opt{mauve}"
set-face global ts_keyword_special "%opt{mauve}"
set-face global ts_keyword_storage "%opt{mauve}"
set-face global ts_keyword_storage_modifier "%opt{mauve}"
set-face global ts_keyword_storage_modifier_mut "%opt{mauve}"

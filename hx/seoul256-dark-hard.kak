declare-option str gray11 "rgb:eeeeee"
declare-option str gray12 "rgb:e4e4e4"
declare-option str gray13 "rgb:bcbcbc"

set-face global Default "%opt{white},%opt{gray1}"

set-face global ts_attribute "%opt{yellow}"
set-face global ts_comment "%opt{green1}"
set-face global ts_comment_block "%opt{green1}"
set-face global ts_comment_line "%opt{green1}"
set-face global ts_constant "%opt{blue5}"
set-face global ts_constant_builtin_boolean "%opt{purple}"
set-face global ts_constant_character "%opt{blue5}"
set-face global ts_constant_character_escape "%opt{salmon}"
set-face global ts_constant_macro "%opt{blue5}"
set-face global ts_constant_numeric "%opt{yellow1}"
set-face global ts_constant_numeric_float "%opt{yellow1}"
set-face global ts_constant_numeric_integer "%opt{yellow1}"
set-face global ts_constructor "%opt{yellow}"
set-face global ts_diff_delta "%opt{blue1}"
set-face global ts_diff_delta_moved "%opt{blue1}"
set-face global ts_diff_minus "%opt{magenta3}"
set-face global ts_diff_plus "%opt{green3}"
set-face global ts_error "%opt{red}+b"
set-face global ts_function "%opt{yellow2}"
set-face global ts_function_builtin "%opt{blue1}"
set-face global ts_function_macro "%opt{yellow2}"
set-face global ts_function_method "%opt{salmon}"
set-face global ts_function_method_private "%opt{salmon}"
set-face global ts_function_special "%opt{yellow2}"
set-face global ts_hint "%opt{blue3}+b"
set-face global ts_info "%opt{blue2}+b"
set-face global ts_keyword "%opt{mauve}"
set-face global ts_keyword_conditional "%opt{mauve}"
set-face global ts_keyword_control "%opt{mauve}"
set-face global ts_keyword_control_conditional "%opt{mauve}"
set-face global ts_keyword_control_directive "%opt{mauve}"

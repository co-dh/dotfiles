# ferra — converted from Helix theme by helix-theme2kak

declare-option str ferra_night "rgb:2b292d"
declare-option str ferra_ash "rgb:383539"
declare-option str ferra_umber "rgb:4d424b"
declare-option str ferra_bark "rgb:6f5d63"
declare-option str ferra_mist "rgb:d1d1e0"
declare-option str ferra_sage "rgb:b1b695"
declare-option str ferra_blush "rgb:fecdb2"
declare-option str ferra_coral "rgb:ffa07a"
declare-option str ferra_rose "rgb:f6b6c9"
declare-option str ferra_ember "rgb:e06b75"
declare-option str ferra_honey "rgb:f5d76e"

set-face global Default "%opt{ferra_blush},%opt{ferra_night}"

set-face global ts_attribute "%opt{ferra_blush}"
set-face global ts_comment "%opt{ferra_bark}+i"
set-face global ts_comment_block "%opt{ferra_bark}+i"
set-face global ts_comment_line "%opt{ferra_bark}+i"

set-face global ts_keyword_storage_type "%opt{ferra_mist}"
set-face global ts_label "%opt{ferra_sage}"
set-face global ts_markup_bold "+b"
set-face global ts_markup_heading "%opt{ferra_sage}+b"
set-face global ts_markup_heading_1 "%opt{ferra_sage}+b"
set-face global ts_markup_heading_2 "%opt{ferra_sage}+b"
set-face global ts_markup_heading_3 "%opt{ferra_sage}+b"

set-face global ts_function_method "%opt{ferra_coral}"
set-face global ts_function_method_private "%opt{ferra_coral}"
set-face global ts_function_special "%opt{ferra_coral}"
set-face global ts_hint "%opt{ferra_blush}"
set-face global ts_info "%opt{ferra_blush}"
set-face global ts_keyword "%opt{ferra_mist}"
set-face global ts_keyword_conditional "%opt{ferra_mist}"
set-face global ts_keyword_control "%opt{ferra_mist}"
set-face global ts_keyword_control_conditional "%opt{ferra_mist}"

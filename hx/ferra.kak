set-face global ts_constant_numeric_integer "%opt{ferra_sage}"
set-face global ts_diff_delta "%opt{ferra_blush}"
set-face global ts_diff_delta_moved "%opt{ferra_blush}"
set-face global ts_diff_minus "%opt{ferra_ember}"
set-face global ts_diff_plus "%opt{ferra_sage}"

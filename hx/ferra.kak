set-face global ts_keyword_control_exception "%opt{ferra_mist}"
set-face global ts_keyword_control_import "%opt{ferra_mist}"
set-face global ts_keyword_control_repeat "%opt{ferra_mist}"
set-face global ts_keyword_control_return "%opt{ferra_mist}"

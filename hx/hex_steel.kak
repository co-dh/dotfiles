# hex_steel — converted from Helix theme by helix-theme2kak

declare-option str t1 "rgb:0e0e0d"
declare-option str t2 "rgb:1d1e1b"
declare-option str t3 "rgb:5b5555"
declare-option str t4 "rgb:656869"
declare-option str t5 "rgb:727b7c"
declare-option str t6 "rgb:6e8789"
declare-option str t7 "rgb:d85c60"
declare-option str t8 "rgb:9bc1bb"
declare-option str t9 "rgb:b5c5c5"
declare-option str t10 "rgb:c3c3bd"
declare-option str t11 "rgb:f78c5e"
declare-option str highlight "rgb:f23672"
declare-option str highlight_two "rgb:f69c3c"
declare-option str highlight_three "rgb:d4d987"
declare-option str selection "rgb:4a9aa6"
declare-option str selection_fg "rgb:080a0b"
declare-option str black "rgb:000000"
declare-option str comment "rgb:654642"
declare-option str comment_doc "rgb:234048"
declare-option str hints "rgb:31353c"
declare-option str ruler "rgb:222320"
declare-option str error "rgb:ff4000"
declare-option str warning "rgb:ffbf00"
declare-option str display "rgb:42baff"
declare-option str info "rgb:dad7d5"
declare-option str diff_minus "rgb:ff4000"
declare-option str diff_delta "rgb:0078bd"
declare-option str diff_plus "rgb:c9d400"
declare-option str diff_delta_moved "rgb:0048bd"

set-face global Default "%opt{t4},%opt{t2}"

set-face global ts_comment ",%opt{comment_doc}+i"
set-face global ts_comment_block ",%opt{comment_doc}+i"
set-face global ts_comment_line ",%opt{comment_doc}+i"
set-face global ts_comment_line_documentation ",%opt{comment_doc}+i"
set-face global ts_constant "%opt{t11}"
set-face global ts_constant_builtin_boolean "%opt{t11}"

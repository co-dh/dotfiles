set-face global ts_constant_character_escape "%opt{t11}"
set-face global ts_constant_macro "%opt{t11}"
set-face global ts_constant_numeric "%opt{t11}"
set-face global ts_constant_numeric_float "%opt{t11}"
set-face global ts_constant_numeric_integer "%opt{t11}"
set-face global ts_diff_delta "%opt{diff_delta}"
set-face global ts_diff_delta_moved "%opt{diff_delta_moved}"
set-face global ts_diff_minus "%opt{diff_minus}"
set-face global ts_diff_plus "%opt{diff_plus}"
set-face global ts_error "%opt{error}+b"
set-face global ts_function "%opt{t10}"
set-face global ts_function_builtin "%opt{t10}"
set-face global ts_function_macro "%opt{t7}"
set-face global ts_function_method "%opt{t7}"
set-face global ts_function_method_private "%opt{t7}"
set-face global ts_function_special "%opt{t10}"
set-face global ts_hint "%opt{display}+b"
set-face global ts_info "%opt{info}+b"
set-face global ts_keyword "%opt{t6}"
set-face global ts_keyword_conditional "%opt{t6}"
set-face global ts_keyword_control "%opt{t8}"
set-face global ts_keyword_control_conditional "%opt{t8}"

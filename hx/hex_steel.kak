set-face global ts_punctuation "%opt{t9}"
set-face global ts_punctuation_bracket "%opt{t9}"
set-face global ts_punctuation_delimiter "%opt{t9}"
set-face global ts_punctuation_special "%opt{t9}"
set-face global ts_special "%opt{t7}+b"
set-face global ts_string "%opt{t6}+i"

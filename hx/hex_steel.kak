set-face global ts_keyword_control_import "%opt{t8}"
set-face global ts_keyword_control_repeat "%opt{t8}"
set-face global ts_keyword_control_return "%opt{t8}"
set-face global ts_keyword_directive "%opt{t6}"
set-face global ts_keyword_function "%opt{t11}"
set-face global ts_keyword_operator "%opt{t6}"
set-face global ts_keyword_special "%opt{t6}"
set-face global ts_keyword_storage "%opt{t6}"
set-face global ts_keyword_storage_modifier "%opt{t7}"

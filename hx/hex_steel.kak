set-face global ts_markup_heading_4 "%opt{t7}"
set-face global ts_markup_heading_5 "%opt{t7}"
set-face global ts_markup_heading_6 "%opt{t7}"
set-face global ts_markup_heading_marker "%opt{t7}"
set-face global ts_markup_italic "%opt{t4}"
set-face global ts_markup_link_text "%opt{t11}"

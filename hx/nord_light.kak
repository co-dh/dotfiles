set-face global ts_markup_heading_marker "%opt{nord0}+b"
set-face global ts_markup_link_text "%opt{nord12}"
set-face global ts_markup_link_url "%opt{nord3}"
set-face global ts_markup_quote "%opt{nord3}+i"
set-face global ts_markup_raw "%opt{nord10}"
set-face global ts_markup_raw_block "%opt{nord10}"
set-face global ts_markup_raw_inline "%opt{nord10}"
set-face global ts_namespace "%opt{nord10}"

# jetbrains_dark — converted from Helix theme by helix-theme2kak

declare-option str red179 "rgb:b3ae60"
declare-option str red194 "rgb:c29e4a"
declare-option str red199 "rgb:c77dbb"
declare-option str red207 "rgb:cf8e6d"
declare-option str red213 "rgb:d5b778"
declare-option str red214 "rgb:d64d5b"
declare-option str green130 "rgb:5f826b"
declare-option str green145 "rgb:549159"
declare-option str green156 "rgb:499c54"
declare-option str green171 "rgb:6aab73"
declare-option str blue34 "rgb:1e1f22"
declare-option str blue46 "rgb:26282e"
declare-option str blue48 "rgb:2b2d30"
declare-option str blue50 "rgb:2d2e32"
declare-option str blue56 "rgb:313438"
declare-option str blue64 "rgb:293c40"
declare-option str blue81 "rgb:4d4e51"
declare-option str blue89 "rgb:4b5059"
declare-option str blue110 "rgb:2e436e"
declare-option str blue122 "rgb:6f737a"
declare-option str blue131 "rgb:214283"
declare-option str blue133 "rgb:7a7e85"
declare-option str blue145 "rgb:868a91"
declare-option str blue171 "rgb:a1a3ab"
declare-option str blue173 "rgb:375fad"
declare-option str blue184 "rgb:2aacb8"
declare-option str blue196 "rgb:bcbec4"
declare-option str blue245 "rgb:56a8f5"
declare-option str blue247 "rgb:57aaf7"

set-face global Default ",%opt{blue34}"

set-face global ts_comment "%opt{green130}"
set-face global ts_comment_block "%opt{green130}"
set-face global ts_comment_line "%opt{green130}"
set-face global ts_comment_line_documentation "%opt{green130}"

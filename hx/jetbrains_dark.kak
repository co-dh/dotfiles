set-face global ts_string_special "%opt{green171}"
set-face global ts_string_special_path "%opt{green171}"
set-face global ts_string_special_symbol "%opt{green171}"
set-face global ts_string_symbol "%opt{green171}"
set-face global ts_tag "%opt{red213}"
set-face global ts_tag_error "%opt{red213}"
set-face global ts_type_builtin "%opt{red207}"
set-face global ts_type_enum "%opt{red199}"
set-face global ts_type_enum_variant "%opt{red199}"
set-face global ts_variable_builtin "%opt{red207}"

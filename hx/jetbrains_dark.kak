set-face global ts_markup_heading_4 "%opt{red199}+i"
set-face global ts_markup_heading_5 "%opt{red199}+i"
set-face global ts_markup_heading_6 "%opt{red199}+i"
set-face global ts_markup_heading_marker "%opt{red207}"
set-face global ts_markup_italic "+i"
set-face global ts_markup_link "%opt{blue247}"
set-face global ts_markup_link_label "%opt{blue247}"
set-face global ts_markup_link_text "%opt{blue247}"
set-face global ts_markup_link_uri "%opt{blue247}"
set-face global ts_markup_link_url "%opt{blue247}"
set-face global ts_markup_list_checked "%opt{red207}"
set-face global ts_markup_list_numbered "%opt{red207}"
set-face global ts_markup_list_unchecked "%opt{red207}"

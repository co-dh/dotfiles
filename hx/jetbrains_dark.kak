set-face global ts_constant_numeric "%opt{blue184}"
set-face global ts_constant_numeric_float "%opt{blue184}"
set-face global ts_constant_numeric_integer "%opt{blue184}"
set-face global ts_diff_delta "%opt{blue173}"
set-face global ts_diff_delta_moved "%opt{blue173}"
set-face global ts_diff_minus "%opt{blue145}"
set-face global ts_diff_plus "%opt{green145}"
set-face global ts_error "%opt{red214}"
set-face global ts_function "%opt{blue245}"
set-face global ts_function_builtin "%opt{blue245}"
set-face global ts_function_macro "%opt{red179}"
set-face global ts_function_method "%opt{blue245}"
set-face global ts_function_method_private "%opt{blue245}"
set-face global ts_function_special "%opt{blue245}"
set-face global ts_hint "%opt{green156}"
set-face global ts_info "%opt{blue247}"
set-face global ts_keyword "%opt{red207}"
set-face global ts_keyword_conditional "%opt{red207}"
set-face global ts_keyword_control "%opt{red207}"
set-face global ts_keyword_control_conditional "%opt{red207}"
set-face global ts_keyword_control_directive "%opt{red207}"
set-face global ts_keyword_control_except "%opt{red207}"
set-face global ts_keyword_control_exception "%opt{red207}"
set-face global ts_keyword_control_import "%opt{red207}"
set-face global ts_keyword_control_repeat "%opt{red207}"
set-face global ts_keyword_control_return "%opt{red207}"
set-face global ts_keyword_directive "%opt{red207}"
set-face global ts_keyword_function "%opt{red207}"
set-face global ts_keyword_operator "%opt{red207}"
set-face global ts_keyword_special "%opt{red207}"
set-face global ts_keyword_storage "%opt{red207}"
set-face global ts_keyword_storage_modifier "%opt{red207}"
set-face global ts_keyword_storage_modifier_mut "%opt{red207}"
set-face global ts_keyword_storage_modifier_ref "%opt{red207}"
set-face global ts_keyword_storage_type "%opt{red207}"
set-face global ts_label "%opt{red199}"
set-face global ts_markup_bold "+b"
set-face global ts_markup_heading "%opt{red199}+i"
set-face global ts_markup_heading_1 "%opt{red199}+i"
set-face global ts_markup_heading_2 "%opt{red199}+i"

set-face global ts_keyword_operator "%opt{bogster_yellow}+b"
set-face global ts_keyword_special "%opt{bogster_yellow}+b"
set-face global ts_keyword_storage "%opt{bogster_yellow}+b"
set-face global ts_keyword_storage_modifier "%opt{bogster_yellow}+b"
set-face global ts_keyword_storage_modifier_mut "%opt{bogster_yellow}+b"
set-face global ts_keyword_storage_modifier_ref "%opt{bogster_yellow}+b"
set-face global ts_keyword_storage_type "%opt{bogster_yellow}+b"
set-face global ts_label "%opt{bogster_blue}"
set-face global ts_markup_bold "%opt{bogster_yellow}+b"
set-face global ts_markup_heading "%opt{bogster_blue}"

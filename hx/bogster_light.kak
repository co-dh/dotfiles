set-face global ts_markup_list_unchecked "%opt{bogster_red}"
set-face global ts_markup_list_unnumbered "%opt{bogster_red}"
set-face global ts_markup_quote "%opt{bogster_lblue}"
set-face global ts_markup_raw "%opt{bogster_teal}"

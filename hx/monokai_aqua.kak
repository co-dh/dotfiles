# monokai_aqua — converted from Helix theme by helix-theme2kak

declare-option str type "rgb:66d9ef"
declare-option str keyword "rgb:f92672"
declare-option str regex "rgb:ce9178"
declare-option str special "rgb:c586c0"
declare-option str variable "rgb:f8f8f2"
declare-option str fn_declaration "rgb:a6e22e"
declare-option str background "rgb:272822"
declare-option str text "rgb:f8f8f2"
declare-option str active_text "rgb:ffffff"
declare-option str cursor "rgb:a6a6a6"
declare-option str inactive_cursor "rgb:878b91"
declare-option str widget "rgb:1e1f1c"
declare-option str selection "rgb:414339"
declare-option str tag "rgb:f92672"
declare-option str cyan "rgb:66d9ef"

set-face global Default "%opt{text},%opt{background}"

set-face global ts_attribute "%opt{fn_declaration}"
set-face global ts_constant "%opt{variable}"
set-face global ts_constant_builtin_boolean "%opt{variable}"
set-face global ts_constant_character "%opt{variable}"
set-face global ts_constant_character_escape "%opt{variable}"
set-face global ts_constant_macro "%opt{variable}"
set-face global ts_constant_numeric "%opt{variable}"
set-face global ts_constant_numeric_float "%opt{variable}"
set-face global ts_constant_numeric_integer "%opt{variable}"
set-face global ts_constructor "%opt{fn_declaration}"
set-face global ts_function "%opt{fn_declaration}"
set-face global ts_function_builtin "%opt{fn_declaration}"
set-face global ts_function_macro "%opt{keyword}"
set-face global ts_function_method "%opt{fn_declaration}"
set-face global ts_function_method_private "%opt{fn_declaration}"
set-face global ts_function_special "%opt{fn_declaration}"
set-face global ts_keyword "%opt{keyword}"
set-face global ts_keyword_conditional "%opt{keyword}"
set-face global ts_keyword_control "%opt{keyword}"
set-face global ts_keyword_control_conditional "%opt{keyword}"
set-face global ts_keyword_control_directive "%opt{keyword}"
set-face global ts_keyword_control_except "%opt{keyword}"
set-face global ts_keyword_control_exception "%opt{keyword}"
set-face global ts_keyword_control_import "%opt{cyan}+i"
set-face global ts_keyword_control_repeat "%opt{keyword}"
set-face global ts_keyword_control_return "%opt{keyword}"
set-face global ts_keyword_directive "%opt{keyword}"
set-face global ts_keyword_function "%opt{cyan}+i"
set-face global ts_keyword_operator "%opt{keyword}"
set-face global ts_keyword_special "%opt{keyword}"
set-face global ts_keyword_storage "%opt{keyword}"
set-face global ts_keyword_storage_modifier "%opt{keyword}"
set-face global ts_keyword_storage_modifier_mut "%opt{keyword}"
set-face global ts_keyword_storage_modifier_ref "%opt{keyword}"
set-face global ts_keyword_storage_type "%opt{cyan}+i"
set-face global ts_label "%opt{keyword}"
set-face global ts_markup_bold "+b"
set-face global ts_markup_italic "+i"
set-face global ts_markup_link_url "+u"
set-face global ts_markup_quote "%opt{cyan}"
set-face global ts_markup_strikethrough "+s"
set-face global ts_module "%opt{type}"
set-face global ts_namespace "%opt{text}"
set-face global ts_operator "%opt{text}"
set-face global ts_punctuation "%opt{text}"
set-face global ts_punctuation_bracket "%opt{text}"
set-face global ts_punctuation_delimiter "%opt{text}"
set-face global ts_punctuation_special "%opt{text}"
set-face global ts_special "%opt{keyword}"
set-face global ts_string_regexp "%opt{regex}"
set-face global ts_tag "%opt{tag}"
set-face global ts_tag_error "%opt{tag}"
set-face global ts_type "%opt{type}+b"
set-face global ts_type_builtin "%opt{type}+b"
set-face global ts_type_enum_variant "%opt{text}"
set-face global ts_variable "%opt{variable}"
set-face global ts_variable_builtin "%opt{keyword}"
set-face global ts_variable_other_member "%opt{variable}"
set-face global ts_variable_other_member_private "%opt{variable}"
set-face global ts_variable_parameter "%opt{variable}"

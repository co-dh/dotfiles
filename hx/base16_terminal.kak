# base16_terminal — converted from Helix theme by helix-theme2kak



set-face global ts_comment "+i"
set-face global ts_comment_block "+i"
set-face global ts_comment_line "+i"
set-face global ts_markup_bold "+b"
set-face global ts_markup_italic "+i"
set-face global ts_markup_link_url "+u"
set-face global ts_markup_strikethrough "+s"
